#!/usr/bin/perl

use Apache::Htpasswd;

my ( $path, $user, $pwd ) = @ARGV;

unless (-f $path) {
    open my $fh, '>', $path or die $!;
    close $fh;
}

die 'Missing args' unless $path and $user and $pwd;
my $hf = new Apache::Htpasswd($path) or die $! . $@;
#$hf->htpasswd( $user, $pwd, { 'overwrite' => 1 } );
$hf->htpasswd( $user, $pwd) || $hf->htpasswd( $user, $pwd, { 'overwrite' => 1 } );
